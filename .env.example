# Twilio Account Credentials
# Get these from: https://console.twilio.com/
ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AUTH_TOKEN=your_auth_token_here

# Twilio Domain Name
# This will be automatically set after deployment
# Format: your-service-name-XXXX-dev.twil.io (or -prod.twil.io for production)
# IMPORTANT: Do not include https:// in DOMAIN_NAME (it will be added automatically)
DOMAIN_NAME=

# Flex Configuration
# Required for Flex handover functionality
# Get these from: https://console.twilio.com/us1/develop/flex/manage/task-assignment/workspaces
FLEX_WORKSPACE_SID=WSxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLEX_WORKFLOW_SID=WWxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Voice SDK Configuration
# Required for Voice Client functionality

# Twilio API Key (create at: https://console.twilio.com/us1/develop/runtime/api-keys/create)
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_api_key_secret_here

# TwiML App SID (create at: https://console.twilio.com/us1/develop/voice/manage/twiml-apps)
# Configure the Voice URL to point to: https://[YOUR_DOMAIN]/voice/voice-sdk-call
VOICE_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Client Identity (optional - defaults to "web-caller")
VOICE_CLIENT_IDENTITY=web-caller

# Twilio Region (optional - leave empty for US, or set to "au1", "ie1", etc.)
# IMPORTANT: Region must match where your API keys and TwiML App were created
# Leave empty or unset to use US region (default)
# Common regions: au1 (Australia), ie1 (Ireland), sg1 (Singapore), jp1 (Japan), de1 (Germany)
REGION=

# Twilio Phone Number (required for outbound calls to phone numbers)
# This number will be used as the caller ID for Voice SDK calls to phone numbers
# Must be a Twilio number you own: https://console.twilio.com/us1/develop/phone-numbers/manage/incoming
TWILIO_MOBILE_NUMBER=

# Voice SDK Call Routing Configuration
# NOTE: All routing parameters below can be overridden via URL parameters
# Example: voice-client.html?assistantSid=ASxxxx&greeting=Hello
# URL parameters take priority over environment variables

# Destination Type: "assistant" | "phone" | "flex" | "custom"
VOICE_SDK_DESTINATION_TYPE=assistant

# For AI Assistant routing (when VOICE_SDK_DESTINATION_TYPE=assistant)
# Can be overridden with: ?assistantSid=ASxxxx
VOICE_SDK_ASSISTANT_SID=

# Can be overridden with: ?greeting=Your%20custom%20greeting
VOICE_SDK_GREETING=Hello! How can I help you today?

# Can be overridden with: ?voiceId=en-US-Neural2-A
VOICE_SDK_VOICE_ID=en-US-Journey-O

# For Phone Number routing (when VOICE_SDK_DESTINATION_TYPE=phone)
# Can be overridden with: ?phoneNumber=+15551234567
VOICE_SDK_PHONE_NUMBER=

